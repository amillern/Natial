{
  "entities": {
    "Order": {
      "title": "Order",
      "description": "A customer order containing items, shipping details, and total cost.",
      "type": "object",
      "properties": {
        "customer": {
          "type": "object",
          "description": "Customer shipping and contact details",
          "properties": {
            "name": { "type": "string", "description": "Full name" },
            "email": { "type": "string", "format": "email" },
            "phone": { "type": "string" },
            "address": { "type": "string" },
            "city": { "type": "string" },
            "country": { "type": "string" },
            "postalCode": { "type": "string" }
          },
          "required": ["name", "email", "phone", "address", "city", "country", "postalCode"]
        },
        "items": {
          "type": "array",
          "description": "List of items purchased",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" },
              "selectedColor": { "type": "string" },
              "selectedSize": { "type": "string" }
            }
          }
        },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customer", "items", "total", "status", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "Admin or registered user profile.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "customer"] }
      },
      "required": ["email", "role"]
    }
  },
  "firestore": {
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Stores all customer orders."
    },
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles and roles."
    }
  }
}
